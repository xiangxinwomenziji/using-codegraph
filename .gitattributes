# 强制脚本与文档用 LF,避免 Windows 上 git core.autocrlf 把 shebang 写成 CRLF
# 这是 Node bin 包在 Linux/macOS 上跑不起来最常见的根因。

* text=auto eol=lf

bin/*.js     text eol=lf
*.md         text eol=lf
*.mjs        text eol=lf
*.json       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# LICENSE 没扩展名,显式标 text
LICENSE      text

# 二进制白名单(目前没有,占位以防后续加图)
*.png        binary
*.jpg        binary
*.gz         binary
